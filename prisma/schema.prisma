// Prisma schema for MyApoBE
// Schema is owned externally — do NOT run `prisma migrate` against the shared DB.
// Use `prisma generate` to refresh the client only.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["tosalpee"]
}

// ─────────────────────────────────────────────────────────────────────
// User · 앱 로그인 (이메일 + 비밀번호)
//   지갑은 non-custodial — 사용자 디바이스에서 seed 생성/보관, 서버는 주소만 안다
// ─────────────────────────────────────────────────────────────────────

model User {
  id           BigInt    @id @default(autoincrement())
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  name         String    @db.VarChar(50)
  nationality  String    @db.VarChar(2)
  personaType  String    @default("KOREAN") @map("persona_type") @db.VarChar(20)
  xrplAddress  String    @unique @map("xrpl_address") @db.VarChar(35)
  status       String    @default("ACTIVE") @db.VarChar(20)
  alias        String?   @db.VarChar(40)
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamp(0)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  isDelete     Boolean   @default(false) @map("is_delete")

  documents Document[]

  @@index([status], map: "idx_users_status")
  @@index([xrplAddress], map: "idx_users_xrpl_address")
  @@map("users")
  @@schema("tosalpee")
}

// ─────────────────────────────────────────────────────────────────────
// Issuer · 발급기관 마스터 (KR-NTS · KR-법원 · VN-MFA …)
// ─────────────────────────────────────────────────────────────────────

model Issuer {
  code          String   @id @map("code") @db.VarChar(20)
  name          String   @db.VarChar(50)
  countryCode   String   @map("country_code") @db.VarChar(2)
  iconLabel     String   @map("icon_label") @db.VarChar(20)
  walletAddress String?  @unique @map("wallet_address") @db.VarChar(35)
  status        String   @default("ACTIVE") @db.VarChar(20)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  isDelete      Boolean  @default(false) @map("is_delete")

  documentTypes DocumentType[]

  @@index([countryCode, status], map: "idx_issuers_country_status")
  @@map("issuers")
  @@schema("tosalpee")
}

// ─────────────────────────────────────────────────────────────────────
// DocumentType · 문서 카탈로그 (발급 신청 시 사용자에게 노출되는 마스터)
// ─────────────────────────────────────────────────────────────────────

model DocumentType {
  code             String   @id @map("code") @db.VarChar(40)
  name             String   @db.VarChar(100)
  englishName      String?  @map("english_name") @db.VarChar(100)
  issuerCode       String   @map("issuer_code") @db.VarChar(20)
  personaType      String   @map("persona_type") @db.VarChar(20)
  useCase          String?  @map("use_case") @db.VarChar(200)
  defaultTtlMonths Int      @default(6) @map("default_ttl_months")
  status           String   @default("ACTIVE") @db.VarChar(20)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  isDelete         Boolean  @default(false) @map("is_delete")

  issuer    Issuer     @relation(fields: [issuerCode], references: [code])
  documents Document[]

  @@index([personaType, status], map: "idx_document_types_persona_status")
  @@index([issuerCode], map: "idx_document_types_issuer")
  @@map("document_types")
  @@schema("tosalpee")
}

// ─────────────────────────────────────────────────────────────────────
// Document · 발급된 문서 (6상태 통합: PROGRESS · AWAITING_APPROVAL · VALID · EXPIRED · REVOKED · FAILED)
//
// 발급 흐름:
//   - Stage RECEIVED      = 기관 자동 발급 (사용자 서명 X)
//   - Stage PRE_REVIEW    = 서류도착 → user 승인 필요  (#1)
//   - Stage TRANSLATING   = 번역/공증 → user 승인 필요  (#2)
//   - Stage NOTARIZING    = 아포스티유 발급 → user 승인 필요  (#3)
//   - Stage ISSUED        = 사용자 지갑 저장 → user CredentialAccept (#4)
//   총 4번의 user 서명 → 모두 끝나면 status=VALID.
//   각 서명 이벤트는 document_approvals 1:N 으로 누적.
// ─────────────────────────────────────────────────────────────────────

model Document {
  id                BigInt    @id @default(autoincrement())
  documentCode      String    @unique @map("document_code") @db.Uuid
  userId            BigInt    @map("user_id")
  documentTypeCode  String    @map("document_type_code") @db.VarChar(40)
  status            String    @default("PROGRESS") @db.VarChar(20)
  currentStage      String    @default("RECEIVED") @map("current_stage") @db.VarChar(20)
  failureReason     String?   @map("failure_reason") @db.Text
  xrplCreateTxHash  String?   @map("xrpl_create_tx_hash") @db.Char(64)
  xrplLedgerIndex   BigInt?   @map("xrpl_ledger_index")
  payloadHash       String?   @map("payload_hash") @db.Char(64)
  requestedAt       DateTime  @default(now()) @map("requested_at") @db.Timestamp(0)
  issuedAt          DateTime? @map("issued_at") @db.Timestamp(0)
  expiresAt         DateTime? @map("expires_at") @db.Timestamp(0)
  revokedAt         DateTime? @map("revoked_at") @db.Timestamp(0)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  isDelete          Boolean   @default(false) @map("is_delete")

  user         User                @relation(fields: [userId], references: [id])
  documentType DocumentType        @relation(fields: [documentTypeCode], references: [code])
  stages       DocumentStage[]
  approvals    DocumentApproval[]

  @@index([userId, requestedAt(sort: Desc)], map: "idx_documents_user_time")
  @@index([status, requestedAt(sort: Desc)], map: "idx_documents_status_time")
  @@index([currentStage, status], map: "idx_documents_stage_status")
  @@index([expiresAt], map: "idx_documents_expires_at")
  @@map("documents")
  @@schema("tosalpee")
}

// ─────────────────────────────────────────────────────────────────────
// DocumentApproval · 사용자 승인 이벤트 (한 문서당 4건 누적)
//   각 승인 단계마다 user 가 자기 seed 로 서명한 XRPL TX 를 보관.
//   COUNT(*) = 4 (또는 status=VALID 도달 조건) 이면 모든 단계 승인 완료.
// ─────────────────────────────────────────────────────────────────────

model DocumentApproval {
  id          BigInt   @id @default(autoincrement())
  documentId  BigInt   @map("document_id")
  stage       String   @db.VarChar(20)
  xrplTxHash  String   @map("xrpl_tx_hash") @db.Char(64)
  approvedAt  DateTime @map("approved_at") @db.Timestamp(0)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  isDelete    Boolean  @default(false) @map("is_delete")

  document Document @relation(fields: [documentId], references: [id])

  @@unique([documentId, stage], map: "uniq_document_approvals_doc_stage")
  @@index([documentId, approvedAt], map: "idx_document_approvals_doc_time")
  @@map("document_approvals")
  @@schema("tosalpee")
}

// ─────────────────────────────────────────────────────────────────────
// DocumentStage · 5단계 파이프라인 이벤트 로그 (TX#1~6 사슬)
//   RECEIVED → PRE_REVIEW → TRANSLATING → NOTARIZING → ISSUED
//   행 단위 = "이 단계가 시작/완료/실패했다" 이벤트. 한 문서당 N행 누적.
// ─────────────────────────────────────────────────────────────────────

model DocumentStage {
  id            BigInt    @id @default(autoincrement())
  documentId    BigInt    @map("document_id")
  stage         String    @db.VarChar(20)
  status        String    @db.VarChar(20)
  txHash        String?   @map("tx_hash") @db.Char(64)
  s3ObjectKey   String?   @map("s3_object_key") @db.VarChar(255)
  startedAt     DateTime? @map("started_at") @db.Timestamp(0)
  completedAt   DateTime? @map("completed_at") @db.Timestamp(0)
  failureReason String?   @map("failure_reason") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  isDelete      Boolean   @default(false) @map("is_delete")

  document Document @relation(fields: [documentId], references: [id])

  @@index([documentId, createdAt], map: "idx_document_stages_doc_time")
  @@index([stage, status], map: "idx_document_stages_stage_status")
  @@map("document_stages")
  @@schema("tosalpee")
}
