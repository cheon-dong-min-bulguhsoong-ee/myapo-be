// Prisma schema for MyApoBE
// Schema is owned externally — do NOT run `prisma migrate` against the shared DB.
// Use `prisma generate` to refresh the client only.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["tosalpee"]
}

// ─────────────────────────────────────────────────────────────────────
// User · 웹/앱 로그인 (Web3Auth Login Provider = GOOGLE | KAKAO | LINE | NAVER)
//   지갑은 self-custodial — 사용자 디바이스에서 seed 생성/보관, 서버는 주소와 검증을 위한 정보만 저장
// ─────────────────────────────────────────────────────────────────────
model User {
  id          BigInt @id @default(autoincrement())
  email       String @unique @db.VarChar(255)
  name          String @db.VarChar(50)
  nationality String @db.VarChar(2)
  role        String @default("USER") @db.VarChar(20)

  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz(0)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(0)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(0)
  isDelete    Boolean   @default(false) @map("is_delete")

  documents                Document[]
  credentialIssueRequests CredentialIssueRequest[]
  credentials              Credential[]
  credentialSubmissions    CredentialSubmission[]
  userWallet               UserWallet? // 1:1 관계 정의

  @@map("users")
  @@schema("tosalpee")
}

model UserWallet {
  id     BigInt @id @default(autoincrement())
  userId BigInt @unique @map("user_id") // 여기서 1:1 관계가 강제됨

  // Web3Auth 인증 핵심 식별자
  // verifier: "google", "kakao" 등 / verifierId: Web3Auth에서 제공하는 고유 식별값 (sub)
  verifier   String @db.VarChar(20)
  verifierId String @map("verifier_id") @db.VarChar(255)

  // XRPL 정보 및 검증 필드
  xrplAddress String @unique @map("xrpl_address") @db.VarChar(35)
  publicKey   String @map("public_key") @db.VarChar(66) // 서버사이드 서명 검증을 위한 필수 데이터

  requestedAt DateTime @default(now()) @map("requested_at") @db.Timestamptz(0)
  activatedAt DateTime @default(now()) @map("activated_at") @db.Timestamptz(0)

  // updatedAt은 상태 변경 추적 및 보안 감사를 위해 반드시 필요함
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 특정 소셜 계정이 다른 User와 연결되는 것을 방지
  @@unique([verifier, verifierId], map: "idx_user_wallets_verifier_composite")
  @@index([xrplAddress], map: "idx_user_wallets_xrpl_address")
  @@map("user_wallets")
  @@schema("tosalpee")
}

// ─────────────────────────────────────────────────────────────────────
// Issuer · 발급기관 마스터 (KR-NTS · KR-법원 · VN-MFA …)
// ─────────────────────────────────────────────────────────────────────

model Issuer {
  code          String   @id @map("code") @db.VarChar(20)
  name          String   @db.VarChar(50)
  countryCode   String   @map("country_code") @db.VarChar(2)
  iconLabel     String   @map("icon_label") @db.VarChar(20)
  walletAddress String?  @unique @map("wallet_address") @db.VarChar(35)
  status        String   @default("ACTIVE") @db.VarChar(20)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  isDelete      Boolean  @default(false) @map("is_delete")

  documentTypes DocumentType[]

  @@index([countryCode, status], map: "idx_issuers_country_status")
  @@map("issuers")
  @@schema("tosalpee")
}

// ─────────────────────────────────────────────────────────────────────
// DocumentType · 문서 카탈로그 (발급 신청 시 사용자에게 노출되는 마스터)
// ─────────────────────────────────────────────────────────────────────

model DocumentType {
  code             String   @id @map("code") @db.VarChar(40)
  name             String   @db.VarChar(100)
  englishName      String?  @map("english_name") @db.VarChar(100)
  issuerCode       String   @map("issuer_code") @db.VarChar(20)
  personaType      String   @map("persona_type") @db.VarChar(20)
  useCase          String?  @map("use_case") @db.VarChar(200)
  defaultTtlMonths Int      @default(6) @map("default_ttl_months")
  status           String   @default("ACTIVE") @db.VarChar(20)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  isDelete         Boolean  @default(false) @map("is_delete")

  issuer                  Issuer                   @relation(fields: [issuerCode], references: [code])
  documents               Document[]
  credentialIssueRequests CredentialIssueRequest[]
  credentials             Credential[]

  @@index([personaType, status], map: "idx_document_types_persona_status")
  @@index([issuerCode], map: "idx_document_types_issuer")
  @@map("document_types")
  @@schema("tosalpee")
}

// ─────────────────────────────────────────────────────────────────────
// Document · 발급된 문서 (6상태 통합: PROGRESS · AWAITING_APPROVAL · VALID · EXPIRED · REVOKED · FAILED)
//
// 발급 흐름:
//   - Stage RECEIVED      = 기관 자동 발급 (사용자 서명 X)
//   - Stage PRE_REVIEW    = 서류도착 → user 승인 필요  (#1)
//   - Stage TRANSLATING   = 번역/공증 → user 승인 필요  (#2)
//   - Stage NOTARIZING    = 아포스티유 발급 → user 승인 필요  (#3)
//   - Stage ISSUED        = 사용자 지갑 저장 → user CredentialAccept (#4)
//   총 4번의 user 서명 → 모두 끝나면 status=VALID.
//   각 서명 이벤트는 document_approvals 1:N 으로 누적.
// ─────────────────────────────────────────────────────────────────────

model Document {
  id               BigInt    @id @default(autoincrement())
  documentCode     String    @unique @map("document_code") @db.Uuid
  userId           BigInt    @map("user_id")
  documentTypeCode String    @map("document_type_code") @db.VarChar(40)
  status           String    @default("PROGRESS") @db.VarChar(40)
  currentStage     String    @default("RECEIVED") @map("current_stage") @db.VarChar(40)
  failureReason    String?   @map("failure_reason") @db.Text
  xrplCreateTxHash String?   @map("xrpl_create_tx_hash") @db.Char(64)
  xrplLedgerIndex  BigInt?   @map("xrpl_ledger_index")
  payloadHash      String?   @map("payload_hash") @db.Char(64)
  requestedAt      DateTime  @default(now()) @map("requested_at") @db.Timestamp(0)
  issuedAt         DateTime? @map("issued_at") @db.Timestamp(0)
  expiresAt        DateTime? @map("expires_at") @db.Timestamp(0)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamp(0)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  isDelete         Boolean   @default(false) @map("is_delete")

  user         User               @relation(fields: [userId], references: [id])
  documentType DocumentType       @relation(fields: [documentTypeCode], references: [code])
  credentialIssueRequests CredentialIssueRequest[]
  stages       DocumentStage[]
  approvals    DocumentApproval[]

  @@index([userId, requestedAt(sort: Desc)], map: "idx_documents_user_time")
  @@index([status, requestedAt(sort: Desc)], map: "idx_documents_status_time")
  @@index([currentStage, status], map: "idx_documents_stage_status")
  @@index([expiresAt], map: "idx_documents_expires_at")
  @@map("documents")
  @@schema("tosalpee")
}

// ─────────────────────────────────────────────────────────────────────
// DocumentApproval · 사용자 승인 이벤트 (한 문서당 4건 누적)
//   각 승인 단계마다 user 가 자기 seed 로 서명한 XRPL TX 를 보관.
//   COUNT(*) = 4 (또는 status=VALID 도달 조건) 이면 모든 단계 승인 완료.
// ─────────────────────────────────────────────────────────────────────

model DocumentApproval {
  id         BigInt   @id @default(autoincrement())
  documentId BigInt   @map("document_id")
  stage      String   @db.VarChar(40)
  xrplTxHash String   @map("xrpl_tx_hash") @db.Char(64)
  approvedAt DateTime @map("approved_at") @db.Timestamp(0)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  isDelete   Boolean  @default(false) @map("is_delete")

  document Document @relation(fields: [documentId], references: [id])

  @@unique([documentId, stage], map: "uniq_document_approvals_doc_stage")
  @@index([documentId, approvedAt], map: "idx_document_approvals_doc_time")
  @@map("document_approvals")
  @@schema("tosalpee")
}

// ─────────────────────────────────────────────────────────────────────
// DocumentStage · 5단계 파이프라인 이벤트 로그 (TX#1~6 사슬)
//   RECEIVED → PRE_REVIEW → TRANSLATING → NOTARIZING → ISSUED
//   행 단위 = "이 단계가 시작/완료/실패했다" 이벤트. 한 문서당 N행 누적.
// ─────────────────────────────────────────────────────────────────────

model DocumentStage {
  id            BigInt    @id @default(autoincrement())
  documentId    BigInt    @map("document_id")
  stage         String    @db.VarChar(40)
  status        String    @db.VarChar(40)
  txHash        String?   @map("tx_hash") @db.Char(64)
  s3ObjectKey   String?   @map("s3_object_key") @db.VarChar(255)
  startedAt     DateTime? @map("started_at") @db.Timestamp(0)
  completedAt   DateTime? @map("completed_at") @db.Timestamp(0)
  failureReason String?   @map("failure_reason") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  isDelete      Boolean   @default(false) @map("is_delete")

  document Document @relation(fields: [documentId], references: [id])

  @@index([documentId, createdAt], map: "idx_document_stages_doc_time")
  @@index([stage, status], map: "idx_document_stages_stage_status")
  @@map("document_stages")
  @@schema("tosalpee")
}

// ─────────────────────────────────────────────────────────────────────
// CredentialIssueRequest · 최신 Credential 발급 요청 (Credential bounded context)
//   MVP: 최신 frontend-design 기준 4-stage 파이프라인을 별도 컨텍스트에서 추적한다.
//   Internal JWT protected API에서 생성된다.
// ─────────────────────────────────────────────────────────────────────

model CredentialIssueRequest {
  id               BigInt    @id @default(autoincrement())
  issueRequestCode String    @unique @map("issue_request_code") @db.Uuid
  userId           BigInt    @map("user_id")
  documentTypeCode String    @map("document_type_code") @db.VarChar(40)
  documentCode        String?   @map("document_code") @db.Uuid
  status           String    @db.VarChar(20)
  currentStage     String    @map("current_stage") @db.VarChar(30)
  requestedAt      DateTime  @map("requested_at") @db.Timestamp(0)
  issuedAt         DateTime? @map("issued_at") @db.Timestamp(0)
  failedAt         DateTime? @map("failed_at") @db.Timestamp(0)
  failureReason    String?   @map("failure_reason") @db.Text
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  isDelete         Boolean   @default(false) @map("is_delete")

  user         User         @relation(fields: [userId], references: [id])
  documentType DocumentType @relation(fields: [documentTypeCode], references: [code])
  document     Document?    @relation(fields: [documentCode], references: [documentCode])
  credential   Credential?

  @@index([userId, requestedAt(sort: Desc)], map: "idx_credential_issue_requests_user_time")
  @@index([documentCode], map: "idx_credential_issue_requests_document")
  @@index([status, currentStage], map: "idx_credential_issue_requests_status_stage")
  @@map("credential_issue_requests")
  @@schema("tosalpee")
}

// ─────────────────────────────────────────────────────────────────────
// Credential · 사용자 보유 크리덴셜
//   XRP Testnet 증적은 credential_xrpl_transactions 에 저장하고,
//   Credential 은 보유/만료/폐기 같은 수명주기와 current_stage snapshot만 보관한다.
// ─────────────────────────────────────────────────────────────────────

model Credential {
  id                 BigInt    @id @default(autoincrement())
  credentialCode     String    @unique @map("credential_code") @db.Uuid
  issueRequestId     BigInt    @unique @map("issue_request_id")
  userId             BigInt    @map("user_id")
  documentTypeCode   String    @map("document_type_code") @db.VarChar(40)
  documentTypeName   String    @map("document_type_name") @db.VarChar(100)
  issuerCode         String    @map("issuer_code") @db.VarChar(20)
  status             String    @db.VarChar(20)
  currentStage       String    @map("current_stage") @db.VarChar(30)
  createdXrplTransactionId  BigInt? @unique @map("created_xrpl_transaction_id")
  acceptedXrplTransactionId  BigInt? @unique @map("accepted_xrpl_transaction_id")
  revokedXrplTransactionId   BigInt? @unique @map("revoked_xrpl_transaction_id")
  issuedAt           DateTime  @map("credential_created_at") @db.Timestamp(0)
  expiresAt          DateTime  @map("expires_at") @db.Timestamp(0)
  revokedAt          DateTime? @map("revoked_at") @db.Timestamp(0)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  isDelete           Boolean   @default(false) @map("is_delete")

  issueRequest CredentialIssueRequest @relation(fields: [issueRequestId], references: [id])
  user         User                   @relation(fields: [userId], references: [id])
  documentType DocumentType           @relation(fields: [documentTypeCode], references: [code])
  submissions      CredentialSubmission[]
  createdXrplTransaction CredentialXrplTransaction? @relation("CredentialCreatedXrplTransaction", fields: [createdXrplTransactionId], references: [id])
  acceptedXrplTransaction CredentialXrplTransaction? @relation("CredentialAcceptedXrplTransaction", fields: [acceptedXrplTransactionId], references: [id])
  revokedXrplTransaction CredentialXrplTransaction? @relation("CredentialRevokedXrplTransaction", fields: [revokedXrplTransactionId], references: [id])
  xrplTransactions CredentialXrplTransaction[] @relation("CredentialAllXrplTransactions")

  @@index([userId, issuedAt(sort: Desc)], map: "idx_credentials_user_created")
  @@index([userId, currentStage], map: "idx_credentials_user_stage")
  @@index([status, expiresAt], map: "idx_credentials_status_expires")
  @@map("credentials")
  @@schema("tosalpee")
}

// ─────────────────────────────────────────────────────────────────────
// CredentialSubmission · 기관 제출 이력
//   Row unit is one credential submitted to one institution request.
// ─────────────────────────────────────────────────────────────────────

model CredentialSubmission {
  id                       BigInt   @id @default(autoincrement())
  submissionCode           String   @unique @map("submission_code") @db.Uuid
  credentialId             BigInt   @map("credential_id")
  credentialCode           String   @map("credential_code") @db.Uuid
  userId                   BigInt   @map("user_id")
  submissionRequestId      String   @map("submission_request_id") @db.VarChar(80)
  recipientInstitutionId   String   @map("recipient_institution_id") @db.VarChar(80)
  recipientInstitutionName String   @map("recipient_institution_name") @db.VarChar(120)
  status                   String   @db.VarChar(20)
  rejectionReason          String?  @map("rejection_reason") @db.Text
  submittedAt              DateTime @map("submitted_at") @db.Timestamp(0)
  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt                DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  isDelete                 Boolean  @default(false) @map("is_delete")

  credential Credential @relation(fields: [credentialId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  @@unique([credentialId, submissionRequestId], map: "uniq_credential_submissions_credential_request")
  @@index([userId, submittedAt(sort: Desc)], map: "idx_credential_submissions_user_time")
  @@map("credential_submissions")
  @@schema("tosalpee")
}


// ─────────────────────────────────────────────────────────────────────
// CredentialXrplTransaction · XRP Testnet XLS-70 transaction evidence
//   Hackathon MVP 검증용 Testnet 로그. Production/mainnet finality를 주장하지 않는다.
// ─────────────────────────────────────────────────────────────────────

model CredentialXrplTransaction {
  id             BigInt   @id @default(autoincrement())
  credentialId   BigInt   @map("credential_id")
  transactionKind String   @map("transaction_kind") @db.VarChar(20)
  network        String   @db.VarChar(40)
  txHash         String   @map("tx_hash") @db.Char(64)
  engineResult   String   @map("engine_result") @db.VarChar(40)
  failureReason  String?  @map("failure_reason") @db.Text
  ledgerIndex    BigInt?  @map("ledger_index")
  validated      Boolean  @default(false)
  feeDrops       String?  @map("fee_drops") @db.VarChar(40)
  accountAddress String   @map("account_address") @db.VarChar(35)
  issuerAddress  String?  @map("issuer_address") @db.VarChar(35)
  subjectAddress String?  @map("subject_address") @db.VarChar(35)
  credentialType String   @map("credential_type") @db.VarChar(128)
  flags          Int?
  objectSnapshot Json?    @map("object_snapshot")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  isDelete       Boolean  @default(false) @map("is_delete")

  credential         Credential @relation("CredentialAllXrplTransactions", fields: [credentialId], references: [id])
  createdForCredential Credential? @relation("CredentialCreatedXrplTransaction")
  acceptedForCredential Credential? @relation("CredentialAcceptedXrplTransaction")
  revokedForCredential Credential? @relation("CredentialRevokedXrplTransaction")

  @@unique([txHash], map: "uniq_credential_xrpl_transactions_tx_hash")
  @@index([credentialId, transactionKind], map: "idx_credential_xrpl_transactions_credential_kind")
  @@index([network, ledgerIndex], map: "idx_credential_xrpl_transactions_network_ledger")
  @@map("credential_xrpl_transactions")
  @@schema("tosalpee")
  }

  // ─────────────────────────────────────────────────────────────────────
  // Dispute · 분쟁 관리 (ADR-003)
  // ─────────────────────────────────────────────────────────────────────

  model Dispute {
  id            String   @id @map("id") @db.VarChar(20)
  status        String   @db.VarChar(20)
  type          String   @db.VarChar(20)
  requestId     String   @map("request_id") @db.VarChar(40)
  requesterId   BigInt   @map("requester_id")
  operatorId    BigInt?  @map("operator_id")
  slaDeadline   DateTime @map("sla_deadline") @db.Timestamptz(0)
  isSlaPaused   Boolean  @default(false) @map("is_sla_paused")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(0)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(0)

  timeline DisputeTimeline[]

  @@index([requesterId], map: "idx_disputes_requester")
  @@index([operatorId, status], map: "idx_disputes_operator_status")
  @@map("disputes")
  @@schema("tosalpee")
  }

  model DisputeTimeline {
  id         BigInt   @id @default(autoincrement())
  disputeId  String   @map("dispute_id") @db.VarChar(20)
  status     String   @db.VarChar(20)
  note       String?  @db.Text
  operatorId BigInt?  @map("operator_id")
  isInternal Boolean  @default(false) @map("is_internal")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(0)

  dispute Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId, createdAt], map: "idx_dispute_timeline_dispute_time")
  @@map("dispute_timeline")
  @@schema("tosalpee")
  }
