// Prisma schema for CredBundleBE
// Schema is owned externally — do NOT run `prisma migrate` against the shared DB.
// Use `prisma generate` to refresh the client only.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["tosalpee"]
}

// ─────────────────────────────────────────────────────────────────────
// Identity
// ─────────────────────────────────────────────────────────────────────

model User {
  id            BigInt   @id @default(autoincrement())
  tossCi        String   @unique @map("toss_ci") @db.VarChar(88)
  tossDi        String?  @map("toss_di") @db.VarChar(64)
  xrplAddress   String   @unique @map("xrpl_address") @db.VarChar(35)
  encryptedSeed String   @map("encrypted_seed") @db.Text
  kmsKeyId      String   @map("kms_key_id") @db.VarChar(255)
  status        String   @default("ACTIVE") @db.VarChar(20)
  alias         String?  @map("alias") @db.VarChar(40)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  isDelete      Boolean  @default(false) @map("is_delete")

  credentialBundles  CredentialBundle[]
  credentialRequests CredentialRequest[]

  @@index([status], map: "idx_users_status")
  @@index([xrplAddress], map: "idx_users_xrpl_address")
  @@map("users")
  @@schema("tosalpee")
}

// ─────────────────────────────────────────────────────────────────────
// Issuer Admin (콘솔 로그인 계정)
// ─────────────────────────────────────────────────────────────────────

model IssuerAdmin {
  id           BigInt   @id @default(autoincrement())
  issuerCode   String   @map("issuer_code") @db.VarChar(20)
  adminId      String   @map("admin_id") @db.VarChar(64)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  status       String   @default("ACTIVE") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  isDelete     Boolean  @default(false) @map("is_delete")

  @@unique([issuerCode, adminId], map: "uq_issuer_admins_code_admin")
  @@index([issuerCode], map: "idx_issuer_admins_code")
  @@map("issuer_admins")
  @@schema("tosalpee")
}

// ─────────────────────────────────────────────────────────────────────
// Credential Bundle (사용자 한 번의 발급 요청 묶음 · SSE 구독 단위)
// ─────────────────────────────────────────────────────────────────────

model CredentialBundle {
  id             BigInt    @id @default(autoincrement())
  bundleCode     String    @unique @map("bundle_code") @db.Uuid
  userId         BigInt    @map("user_id")
  status         String    @default("PENDING") @db.VarChar(20)
  totalCount     Int       @map("total_count")
  completedCount Int       @default(0) @map("completed_count")
  failedCount    Int       @default(0) @map("failed_count")
  requestedAt    DateTime  @default(now()) @map("requested_at") @db.Timestamp(0)
  completedAt    DateTime? @map("completed_at") @db.Timestamp(0)
  expiresAt      DateTime? @map("expires_at") @db.Timestamp(0)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  isDelete       Boolean   @default(false) @map("is_delete")

  user     User                @relation(fields: [userId], references: [id])
  requests CredentialRequest[]

  @@index([userId, requestedAt(sort: Desc)], map: "idx_credential_bundles_user_time")
  @@index([status, requestedAt(sort: Desc)], map: "idx_credential_bundles_status")
  @@map("credential_bundles")
  @@schema("tosalpee")
}

// ─────────────────────────────────────────────────────────────────────
// Credential Request (S2-02 발급 대기 큐)
// ─────────────────────────────────────────────────────────────────────

model CredentialRequest {
  id                 BigInt    @id @default(autoincrement())
  bundleId           BigInt    @map("bundle_id")
  userId             BigInt    @map("user_id")
  issuerCode         String    @map("issuer_code") @db.VarChar(20)
  category           String    @db.VarChar(20)
  status             String    @default("PENDING") @db.VarChar(20)
  failureReason      String?   @map("failure_reason") @db.Text
  xrplTxHash         String?   @map("xrpl_tx_hash") @db.Char(64)
  xrplLedgerIndex    BigInt?   @map("xrpl_ledger_index")
  payloadHash        String?   @map("payload_hash") @db.Char(64)
  requestedTtlMonths Int?      @map("requested_ttl_months")
  requestedAt        DateTime  @default(now()) @map("requested_at") @db.Timestamp(0)
  processedAt        DateTime? @map("processed_at") @db.Timestamp(0)
  revokedAt          DateTime? @map("revoked_at") @db.Timestamp(0)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  isDelete           Boolean   @default(false) @map("is_delete")

  bundle CredentialBundle @relation(fields: [bundleId], references: [id])
  user   User             @relation(fields: [userId], references: [id])

  @@index([issuerCode, status, requestedAt(sort: Desc)], map: "idx_credential_requests_issuer_status")
  @@index([bundleId], map: "idx_credential_requests_bundle")
  @@index([userId, requestedAt(sort: Desc)], map: "idx_credential_requests_user_time")
  @@map("credential_requests")
  @@schema("tosalpee")
}
