# Copy to `.env` and fill in real values. `.env` is git-ignored.
#
# DATABASE_URL: PostgreSQL connection string.
# - 비밀번호의 특수문자는 반드시 URL-encode (e.g. `#` → `%23`, `$` → `%24`).
# - `?schema=<NAME>` 으로 사용할 스키마 명시 (본 프로젝트는 별도 스키마 사용).
DATABASE_URL="postgresql://<DB_USER>:<URL_ENCODED_PASSWORD>@<DB_HOST>:5432/<DB_NAME>?schema=<DB_SCHEMA>"

# Application
PORT=4000
NODE_ENV=development

# Auth — Web3Auth / Google OAuth
# Web3AuthGuard 가 부팅 시 강제로 읽음 — 비어 있으면 앱이 뜨지 않는다.
# Google Cloud Console 또는 Web3Auth Dashboard 의 Client ID 를 사용한다.
GOOGLE_OAUTH_CLIENT_ID=
WEB3AUTH_CLIENT_ID=

# Auth — 내부 Access Token (TokenProvider)
# JWT_SECRET 은 절대 커밋 금지. 32바이트 이상 random hex 권장 (e.g. `openssl rand -hex 32`).
JWT_SECRET=
JWT_EXPIRES_IN=1h

# Object Storage (S3-compatible) — 문서 첨부 파일 업/다운로드.
# AWS S3 / Cloudflare R2 / MinIO / Backblaze B2 / Wasabi 등 어떤 백엔드든 동일 SDK 로 동작.
# - S3_ENDPOINT          : 비워두면 AWS S3 기본 endpoint. R2 는 https://<acc>.r2.cloudflarestorage.com
# - S3_BUCKET            : 사용할 버킷 이름. 본 프로젝트 기본값은 `myapo`.
# - S3_REGION (optional) : AWS 면 `us-east-1` 등. R2 는 'auto' (기본값).
# - S3_FORCE_PATH_STYLE  : 'true' 권장. AWS 가상 호스트 스타일 쓰려면 'false'.
# - S3_PUBLIC_BASE_URL   : 익명 GET 이 가능한 public URL 베이스. R2 는 대시보드의 "R2.dev subdomain"
#                          활성화 후 발급되는 `https://pub-<hash>.r2.dev` 형식. 미설정 시 document-mvp
#                          detail 응답의 pdfUrl 이 null 로 나간다.
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=myapo
S3_PUBLIC_BASE_URL=
